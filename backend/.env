# ============================================
# CRITICAL: UPDATE THESE VALUES
# ============================================

# 1. YOUR CLAUDE API KEY (Get from: https://console.anthropic.com/)
ANTHROPIC_API_KEY=[placeholder]

# ============================================
# CHAT AGENT MODEL BACKEND
# ============================================
# Local Ollama models — no API key required.
#   qwen3_vl   → qwen3-vl:2b        (default)
#   gemma3_it  → gemma3:4b-it-qat   (alternative)
CHAT_MODEL_BACKEND=qwen3_vl

# ============================================
# SEMANTIC AI MODEL BACKEND
# ============================================
# Priority list (comma-separated). First working backend wins.
# Options: ollama, gemini_api, anthropic_api
SEMANTIC_BACKEND_PRIORITY=ollama
SEMANTIC_MODEL_BACKEND=ollama

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_URL=http://localhost:11434
# Primary vision model for semantic analysis (floor plan understanding).
# Falls back through VISION_CANDIDATES list if not installed.
OLLAMA_MODEL=aisingapore/Gemma-SEA-LION-v4-4B-VL:latest



# Path to local models directory (used when SEMANTIC_MODEL_BACKEND is local_*)
# Default: ../models  (one level up from project root)
LOCAL_MODELS_DIR=../models


# ============================================
# REVIT SERVER SETTINGS (unchanged)
# ============================================
# 2. YOUR WINDOWS MACHINE IP ADDRESS
# Find Windows IP: Run "ipconfig" on Windows CMD
# Look for "IPv4 Address"
# WINDOWS_REVIT_SERVER=http://191.168.124.64:5000
WINDOWS_REVIT_SERVER=http://LT-HQ-277:5000
#                           ↑↑↑↑↑↑↑↑↑↑↑↑↑↑
#                     REPLACE WITH YOUR WINDOWS IP

# 3. SECURE API KEY (generate a random string)
# This must match the Windows server config
REVIT_SERVER_API_KEY=my-revit-key-2023                                ## my-super-secret-key-12345
#                    ↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑↑
#              REPLACE WITH RANDOM SECURE STRING

# ============================================
# OPTIONAL: You can leave these as default
# ============================================

APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf

DEFAULT_WALL_HEIGHT=2800
DEFAULT_FLOOR_THICKNESS=200
DEFAULT_CEILING_HEIGHT=3000

# ============================================
# VISION ANNOTATION ACCURACY
# ============================================
# Max vision LLM calls used to read element annotations (dimensions, type marks)
# from the PDF raster image.  Elements beyond this cap fall back to the safe
# structural default (200 mm).
#
# Raise this when your use case demands high accuracy:
#   Cost estimation / QS takeoff  →  VISION_ANNOTATION_MAX_CALLS=100
#   MEP coordination               →  VISION_ANNOTATION_MAX_CALLS=100
#   Quick preview / testing        →  VISION_ANNOTATION_MAX_CALLS=10 (default)
#
# Each call uses ~1 Gemini Flash API call; 100 calls ≈ 0.5 s extra latency.
VISION_ANNOTATION_MAX_CALLS=10

# ============================================
# PER-ELEMENT DETECTION AGENTS
# ============================================
COLUMN_CONF_THRESHOLD=0.25       # YOLO confidence threshold for ColumnDetectionAgent

# ============================================
# INTELLIGENCE MIDDLEWARE
# ============================================
MAX_GRID_DIST_PX=80              # Max px distance from grid line before "off_grid" flag
ISOLATION_RADIUS_PX=200          # Max px radius for neighbourhood consensus check
MIN_BAY_MM=3000                  # DfMA minimum bay spacing (SS CP 65)
MAX_BAY_MM=12000                 # DfMA maximum bay spacing (SS CP 65)